<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <!-- Filter pour les cartes NDEF (plus courant) -->
    <tech-list>
        <tech>android.nfc.tech.Ndef</tech>
    </tech-list>
    
    <!-- Filter pour les cartes ISO 14443-4 (cartes bancaires, CI) -->
    <tech-list>
        <tech>android.nfc.tech.IsoDep</tech>
    </tech-list>
    
    <!-- Filter pour les cartes Mifare -->
    <tech-list>
        <tech>android.nfc.tech.NfcA</tech>
        <tech>android.nfc.tech.MifareClassic</tech>
    </tech-list>
    
    <!-- Filter pour les cartes NfcA simples -->
    <tech-list>
        <tech>android.nfc.tech.NfcA</tech>
    </tech-list>
</resources>